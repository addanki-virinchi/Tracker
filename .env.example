# Example environment configuration. Copy to ".env" and fill in real values.
# Do not commit your real ".env" file.

# Flask session signing key. Generate a strong, random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Administrator credentials. These are the source of truth for admin access
# and are applied automatically on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Firebase Realtime Database URL.
FIREBASE_DATABASE_URL=https://personal-f48e3-default-rtdb.firebaseio.com/

# Firebase service account file path, or set FIREBASE_CREDENTIALS_JSON instead.
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Number of days a "remember me" login session stays active.
REMEMBER_DAYS=30
